{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "baseUrl": ".",
    "moduleDetection": "force"
  },
  "include": ["**/*.ts", "**/*.js"],
  "exclude": ["node_modules", "../frontend", "tests"]
}
